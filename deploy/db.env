# LOCAL stack values only (used by compose.override.yml's Postgres). In
# production this file is NOT the one in git: deploy-server provisioning writes
# the real db.env (generated credentials) beside compose.yml on the server, and
# CI never pushes this copy. Committed so `docker compose up` works out of the
# box; matches db/dev-init.sql.
PGHOST=postgres
PGPORT=5432
PGDATABASE=apps
PGUSER=plumber_base
PGPASSWORD=plumber_base
DATABASE_URL=postgres://plumber_base:plumber_base@postgres:5432/apps
