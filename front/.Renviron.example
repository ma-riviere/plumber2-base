# front dev environment. Copy to .Renviron (gitignored) and fill secrets.

# Core
PORT=8080
HOST=0.0.0.0
ENVIRONMENT=dev
BYPASS_AUTH=true
LOG_LEVEL=debug

# Postgres (dev compose: host 127.0.0.1, port 5433, app role plumber_base)
PGHOST=127.0.0.1
PGPORT=5433
PGDATABASE=apps
PGUSER=plumber_base
PGPASSWORD=plumber_base

# URLs
APP_URL=http://localhost:8080
BACKEND_URL=http://127.0.0.1:8081
BACKEND_PUBLIC_URL=http://localhost:8081

# Auth0 (skipped in dev while BYPASS_AUTH=true; fill from the tenant otherwise)
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_AUDIENCE=
AUTH0_MGMT_CLIENT_ID=
AUTH0_MGMT_CLIENT_SECRET=

# Session/crypto: sodium key (also derives refresh-token encryption and CSRF HMAC keys)
SESSION_KEY=
